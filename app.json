{
  "expo": {
    "name": "Al-Maslamani",
    "slug": "Al-Maslamani",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo2.png",
    "scheme": "al-maslamani",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.almaslamani.app",
      "config": {
        "googleMapsApiKey": "AIzaSyC3aHQe8nGPsjiO2laPr9QZvEMNhCAeVWg"
      }
    },
    "android": {
      "package": "com.almaslamani.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo-transparent.png",
        "monochromeImage": "./assets/images/logo-transparent.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC3aHQe8nGPsjiO2laPr9QZvEMNhCAeVWg"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-small.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
      }
    }
  }
}
